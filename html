<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fingani Mbulo & Lesedi Kgosi — RSVP</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cinzel:wght@400;600&family=Raleway:wght@300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#b8935a;
  --gold-light:#dfc08a;
  --cream:#fdf9f4;
  --dark:#0e1a14;
  --mid:#1e3028;
}
body{background:var(--dark);color:var(--cream);font-family:'Raleway',sans-serif;min-height:100vh;overflow-x:hidden}
.page{max-width:680px;margin:0 auto;padding:0 0 60px}

/* Hero */
.hero{position:relative;height:560px;overflow:hidden}
.hero-img{width:100%;height:100%;object-fit:cover;object-position:center top;filter:brightness(0.5) saturate(1.1)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(14,26,20,0.1) 20%,var(--dark) 100%)}
.hero-text{position:absolute;bottom:38px;left:0;right:0;text-align:center;padding:0 24px}
.together{font-family:'Raleway',sans-serif;font-weight:300;font-size:11px;letter-spacing:7px;text-transform:uppercase;color:var(--gold-light);display:block;margin-bottom:14px;opacity:0;animation:fadeUp 1s 0.3s ease forwards}
.names{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,8vw,58px);font-weight:300;font-style:italic;line-height:1.15;color:var(--cream);opacity:0;animation:fadeUp 1s 0.6s ease forwards}
.names span{color:var(--gold)}
.amp{color:var(--gold-light);font-size:0.78em}

/* Dividers */
.ornament{text-align:center;padding:28px 0 20px;color:var(--gold);font-size:16px;letter-spacing:10px;opacity:0;animation:fadeUp 1s 0.9s ease forwards}

/* Details */
.details-block{text-align:center;padding:0 24px;opacity:0;animation:fadeUp 1s 1.1s ease forwards}
.event-label{font-family:'Cinzel',serif;font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:10px}
.event-date{font-family:'Cormorant Garamond',serif;font-size:30px;font-weight:300;color:var(--cream);line-height:1.35}
.event-venue{font-family:'Cormorant Garamond',serif;font-size:21px;font-style:italic;color:var(--gold-light);margin-top:6px}
.event-location{font-size:12px;letter-spacing:3px;color:#8aaa99;margin-top:4px;text-transform:uppercase}
.line{width:60px;height:1px;background:var(--gold);margin:22px auto;opacity:0.5}

/* RSVP */
.rsvp-section{padding:0 24px;opacity:0;animation:fadeUp 1s 1.4s ease forwards}
.rsvp-title{font-family:'Cinzel',serif;font-size:13px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);text-align:center;margin-bottom:28px}
.form-group{margin-bottom:18px}
label{display:block;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold-light);margin-bottom:8px}
input,select,textarea{width:100%;background:transparent;border:none;border-bottom:1px solid #2e4a3a;padding:10px 0;color:var(--cream);font-family:'Raleway',sans-serif;font-size:15px;outline:none;transition:border-color 0.3s;-webkit-appearance:none;resize:none}
select option{background:#0e1a14;color:var(--cream)}
input:focus,select:focus,textarea:focus{border-bottom-color:var(--gold)}
input::placeholder,textarea::placeholder{color:#3a5a48}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.rsvp-btn{width:100%;margin-top:32px;padding:16px;background:transparent;border:1px solid var(--gold);color:var(--gold);font-family:'Cinzel',serif;font-size:11px;letter-spacing:5px;text-transform:uppercase;cursor:pointer;transition:all 0.3s ease}
.rsvp-btn:hover{background:var(--gold);color:var(--dark)}

/* Thank you */
.thankyou{display:none;text-align:center;padding:40px 24px}
.thankyou.show{display:block}
.thankyou-emoji{font-size:48px;display:block;margin-bottom:16px}
.thankyou-title{font-family:'Cormorant Garamond',serif;font-size:32px;font-style:italic;color:var(--gold);margin-bottom:12px}
.thankyou-msg{font-size:14px;color:#8aaa99;line-height:1.7;max-width:340px;margin:0 auto}
.rsvp-form{transition:opacity 0.4s}
.rsvp-form.hidden{opacity:0;pointer-events:none}

/* Footer */
.footer-note{text-align:center;padding:40px 24px 0;font-size:11px;color:#2e4a3a;letter-spacing:1px;line-height:1.8}

@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>
<div class="page">

  <div class="hero">
    <img class="hero-img" src="data:image/jpeg;base64," alt="Fingani & Lesedi">
    <div class="hero-overlay"></div>
    <div class="hero-text">
      <span class="together">Together with their families</span>
      <div class="names">
        <span>Fingani Mbulo</span><br>
        <span class="amp">&amp;</span><br>
        <span>Lesedi Kgosi</span>
      </div>
    </div>
  </div>

  <div class="ornament">✦ &nbsp; ✦ &nbsp; ✦</div>

  <div class="details-block">
    <span class="event-label">Joyfully invite you to their wedding reception</span>
    <div class="event-date">Saturday, the Twenty-Second of August<br>Two Thousand &amp; Twenty-Six</div>
    <div class="line"></div>
    <div class="event-venue">Masa Square Hotel</div>
    <div class="event-location">Gaborone · Botswana</div>
    <div class="line"></div>
    <div style="font-size:13px;color:#5a8a72;letter-spacing:1px;">Reception at 15:00 &nbsp;·&nbsp; Dinner &amp; Dancing to follow</div>
  </div>

  <div class="ornament" style="animation-delay:1.6s">— ❧ —</div>

  <div class="rsvp-section">
    <div class="rsvp-title">Kindly Reply by 22 July 2026</div>

    <div class="rsvp-form" id="rsvpForm">
      <div class="form-group">
        <label>Full Name</label>
        <input type="text" placeholder="Your full name" id="fullname">
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" placeholder="your@email.com" id="email">
      </div>
      <div class="row2">
        <div class="form-group">
          <label>Attendance</label>
          <select id="attending">
            <option value="">Select...</option>
            <option value="yes">Joyfully accepts</option>
            <option value="no">Regretfully declines</option>
          </select>
        </div>
        <div class="form-group">
          <label>Number of Guests</label>
          <select id="guests">
            <option value="1">1 — Just me</option>
            <option value="2">2 — Myself &amp; partner</option>
            <option value="3">3</option>
            <option value="4">4</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Dietary Requirements</label>
        <input type="text" placeholder="Vegetarian, halal, allergies..." id="dietary">
      </div>
      <div class="form-group">
        <label>A Message for the Couple</label>
        <textarea rows="2" placeholder="Share your love &amp; wishes..." id="message"></textarea>
      </div>
      <button class="rsvp-btn" onclick="submitRSVP()">Confirm my RSVP</button>
    </div>

    <div class="thankyou" id="thankYou">
      <span class="thankyou-emoji">🌿</span>
      <div class="thankyou-title">We'll see you there.</div>
      <p class="thankyou-msg">Thank you — your RSVP has been received. We are so excited to celebrate with you. Directions &amp; details will follow closer to the date.</p>
    </div>
  </div>

  <div class="footer-note">
    Fingani Mbulo &amp; Lesedi Kgosi · Masa Square Hotel · Gaborone · 22 August 2026
  </div>

</div>
<script>
function submitRSVP(){
  var name=document.getElementById('fullname').value.trim();
  var email=document.getElementById('email').value.trim();
  var attending=document.getElementById('attending').value;
  if(!name){alert('Please enter your name.');return;}
  if(!email){alert('Please enter your email address.');return;}
  if(!attending){alert('Please let us know if you can attend.');return;}
  document.getElementById('rsvpForm').classList.add('hidden');
  setTimeout(function(){document.getElementById('thankYou').classList.add('show');},400);
}
</script>
</body>
</html>
